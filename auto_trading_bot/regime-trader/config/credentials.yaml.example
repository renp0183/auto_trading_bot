# ============================================================
# Credentials Template — DO NOT commit the real file
# Copy to credentials.yaml and fill in your actual keys.
# credentials.yaml is listed in .gitignore.
# ============================================================

alpaca:
  api_key: "YOUR_ALPACA_API_KEY"
  secret_key: "YOUR_ALPACA_SECRET_KEY"
  paper: true                          # true = paper trading endpoint

# Optional: email alerts
smtp:
  host: "smtp.gmail.com"
  port: 587
  username: "your_email@gmail.com"
  password: "your_app_password"
  recipient: "alerts@yourdomain.com"

# Optional: webhook alerts (Slack, Discord, etc.)
webhook:
  url: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
